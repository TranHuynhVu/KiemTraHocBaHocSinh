@model IEnumerable<TuyenSinh.Models.Nganh>
@{
    ViewData["Title"] = "Quản lý ngành học";
    ViewData["PageTitle"] = "Quản lý ngành học";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 px-4 d-flex align-items-center justify-content-between">
                <h5 class="mb-0 font-weight-700 major-title">
                    <i class="fa-solid fa-graduation-cap text-primary me-2"></i>Danh sách ngành tuyển sinh
                </h5>
                <div class="d-flex gap-2">
                    <span class="badge bg-primary px-3 py-2 rounded-pill d-flex align-items-center badge-count">@Model.Count() Ngành học</span>
                    <button class="btn btn-primary btn-sm px-3 btn-import-excel" data-bs-toggle="modal" data-bs-target="#importModal">
                        <i class="fa-solid fa-file-excel me-1"></i> Nhập Excel ngành
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="nganhTable" class="table table-striped table-bordered w-100">
                        <thead>
                            <tr>
                                <th style="width: 70px;">STT</th>
                                <th style="width: 120px;">Mã ngành</th>
                                <th>Tên ngành - Chuyên ngành</th>
                                <th style="width: 110px;">Hệ số THPT</th>
                                <th style="width: 110px;">Hệ số HB</th>
                                <th>Tổ hợp xét tuyển</th>
                                <th style="width: 160px;">Ngưỡng đầu vào</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int idx = 0;
                            }
                            @foreach (var item in Model)
                            {
                                idx = idx + 1;
                                <tr>
                                    <td class="font-weight-600 text-muted">@idx</td>
                                    <td>
                                        <span class="cccd-link">@item.MaNganh</span>
                                    </td>
                                    <td class="font-weight-600 major-name">@item.TenNganh</td>
                                    <td>
                                        <strong>@item.HeSoTHPT.ToString("0.0")</strong>
                                    </td>
                                    <td>
                                        <strong>@item.HeSoHB.ToString("0.0")</strong>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            @if (item.ToHopNganhs != null && item.ToHopNganhs.Any())
                                            {
                                                foreach (var th in item.ToHopNganhs)
                                                {
                                                    <span class="badge bg-secondary badge-combo-major">@th.ToHopMon.MaToHop</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted small">@item.ToHopXetTuyen</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-warning text-dark px-2 py-1 badge-gate-score">
                                            @item.NgungDauVao
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Nhập Excel -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg modal-import-content">
            <div class="modal-header bg-light border-0 py-3 px-4">
                <h5 class="modal-title font-weight-700 modal-import-title" id="importModalLabel">Nhập dữ liệu ngành tuyển sinh</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Admin" asp-action="ImportNganh" enctype="multipart/form-data" method="post">
                <div class="modal-body p-4">
                    <!-- Note/Banner using variables -->
                    <div class="alert border-0 shadow-sm mb-4 d-flex align-items-start gap-2 alert-import-info">
                        <i class="fa-solid fa-circle-info mt-1 fs-5"></i>
                        <div>
                            <strong class="d-block mb-1">Thông tin ngành tuyển sinh theo phương thức xét kết hợp</strong>
                            <p class="small mb-0 opacity-90">Hệ thống sẽ nạp danh sách ngành học từ tệp Excel, tự động ánh xạ và liên kết các mã tổ hợp xét tuyển tương ứng vào cơ sở dữ liệu.</p>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-600 text-secondary">Chọn tệp tin Excel chứa danh sách ngành</label>
                        <input type="file" name="file" class="form-control" accept=".xlsx, .xls" required />
                        <div class="form-text text-muted small mt-2">
                            Hỗ trợ tệp tin Excel (.xlsx, .xls) chứa trang bảng tính có tiêu đề ngành và chuyên ngành.
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 py-3 px-4 d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-secondary px-3 py-2 btn-sm" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-3 py-2 btn-sm">
                        <i class="fa-solid fa-cloud-arrow-up me-1"></i> Tải lên và Nạp dữ liệu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#nganhTable').DataTable({
                language: {
                    url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                },
                pageLength: 10,
                lengthMenu: [5, 10, 25, 50],
                columnDefs: [
                    { orderable: false, targets: 5 } // Disable sorting on the combinations column
                ]
            });
        });
    </script>
}
